# Production Analyst Environment Variables

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY=

# JWT_SECRET: Secret key for signing authentication tokens.
JWT_SECRET=production_analyst_secret_key_123

# PostgreSQL connection.
# Prefer a full connection string via DATABASE_URL.
DATABASE_URL=postgresql://postgres:Admin@123@localhost:5432/production_analyst

# Optional discrete PostgreSQL settings if DATABASE_URL is not used.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=Admin@123
PGDATABASE=production_analyst
PGSSL=false
PGSSL_REJECT_UNAUTHORIZED=false

# APP_URL: The URL where this applet is hosted.
APP_URL=http://localhost:3000
